# LIME EXPLAINABILITY 
# Shows which image regions influence DR predictions
import numpy as np
import matplotlib.pyplot as plt
from skimage.segmentation import mark_boundaries
import cv2

# Install LIME
try:
    from lime import lime_image
    print(" LIME  installed")
except:
    print(" Installing LIME.")
    import subprocess
    subprocess.check_call(['pip', 'install', 'lime', '--quiet'])
    from lime import lime_image
    print(" LIME installed successfully")

print("\n Setting up LIME explainer.")

# LIME treats your model as a black box - no wrapper issues!
explainer = lime_image.LimeImageExplainer()

def predict_fn(images):

    # LIME  pass images in different format, normalize them
    if images.max() > 1.0:
        images = images / 255.0

    # Get predictions from wrapped model
    preds = models['DenseNet121'].predict(images, verbose=0)
    return preds

print(" LIME explainer ready!")

print("\n Selecting sample images.")
sample_indices = []

for class_idx in range(len(class_names)):
    class_mask = (true_labels == class_idx)
    class_correct = class_mask & (optimal_predictions == class_idx)

    if np.sum(class_correct) > 0:
        correct_idx = np.where(class_correct)[0]
        if len(correct_idx) > 0:
            sample_indices.append(correct_idx[0])

sample_indices = sample_indices[:5]
print(f" Selected {len(sample_indices)} samples")
print("\n Loading validation images.")
val_generator.reset()
all_images = []
for batch in val_generator:
    all_images.extend(batch[0])
    if len(all_images) >= val_generator.samples:
        break
all_images = np.array(all_images[:val_generator.samples])
print(f" Loaded {len(all_images)} images")

print("\n Generating LIME explanations.")

fig, axes = plt.subplots(len(sample_indices), 4, figsize=(16, 4*len(sample_indices)))
if len(sample_indices) == 1:
    axes = axes.reshape(1, -1)

fig.suptitle('LIME Explainability: Important Regions for DR Detection',
             fontsize=16, fontweight='bold', y=0.995)

for idx, sample_idx in enumerate(sample_indices):
    print(f"\n   Processing sample {idx+1}/{len(sample_indices)}...")

    img = all_images[sample_idx]
    true_class = true_labels[sample_idx]
    pred_class = optimal_predictions[sample_idx]

    # ing to 0-255 range for LIME
    img_lime = (img * 255).astype(np.uint8)

    try:
        # Generating LIME explanation
        # num_samples: more = better quality but slower (100-1000 is good)
        # num_features: how many superpixels to highlight (10-20 is good)
        print(f"      Analyzing image regions...")
        explanation = explainer.explain_instance(
            img_lime,
            predict_fn,
            top_labels=len(class_names),
            hide_color=0,
            num_samples=500,  # Number of perturbed samples
            batch_size=32
        )

        # Get explanation for predicted class
        temp, mask = explanation.get_image_and_mask(
            pred_class,
            positive_only=True,  # Only show positive contributions
            num_features=10,     # Top 10 important regions
            hide_rest=False
        )

        print(f"       LIME explanation  is generated!")

        # Create visualization
        img_with_mask = mark_boundaries(img_lime / 255.0, mask)

        # Create heatmap-style visualization
        heatmap = np.zeros(img.shape[:2])
        for i in range(1, mask.max() + 1):
            heatmap[mask == i] = 1.0

        # Apply colormap
        heatmap_colored = cv2.applyColorMap(np.uint8(255 * heatmap), cv2.COLORMAP_JET)
        heatmap_colored = cv2.cvtColor(heatmap_colored, cv2.COLOR_BGR2RGB)

        # Create overlay
        overlay = cv2.addWeighted(img_lime, 0.6, heatmap_colored, 0.4, 0)

    except Exception as e:
        print(f"       Error: {str(e)[:60]}")
        img_with_mask = img
        overlay = img_lime
        heatmap = np.zeros(img.shape[:2])

    # Plot results
    axes[idx, 0].imshow(img)
    axes[idx, 0].set_title('Original Image', fontsize=10, fontweight='bold')
    axes[idx, 0].axis('off')

    axes[idx, 1].imshow(heatmap, cmap='jet')
    axes[idx, 1].set_title('Important Regions', fontsize=10, fontweight='bold')
    axes[idx, 1].axis('off')

    axes[idx, 2].imshow(overlay)
    axes[idx, 2].set_title('Overlay', fontsize=10, fontweight='bold')
    axes[idx, 2].axis('off')

    axes[idx, 3].axis('off')

    # Info box
    is_correct = (pred_class == true_class)
    color = 'green' if is_correct else 'red'
    status = ' CORRECT' if is_correct else ' WRONG'

    info = f"True: {class_names[true_class]}\n"
    info += f"Pred: {class_names[pred_class]}\n"
    info += f"{status}\n\n"
    info += f"Model Acc: {optimal_accuracy:.1f}%\n\n"
    info += "Highlighted regions\n"
    info += "are most important\n"
    info += "for the prediction\n\n"
    info += "Red = Important\n"
    info += "Blue = Less important"

    axes[idx, 3].text(0.1, 0.5, info,
                     fontsize=9, verticalalignment='center',
                     bbox=dict(boxstyle='round', facecolor='white',
                              edgecolor=color, linewidth=2.5))

plt.tight_layout()
plt.savefig('/content/drive/MyDrive/DR_Models/lime_explainability.png',
            dpi=300, bbox_inches='tight')
plt.show()

print("\n Main visualization saved!")

print("\n Saving individual examples...")

for i, sample_idx in enumerate(sample_indices[:3]):
    print(f"   Processing example {i+1}/3...")

    img = all_images[sample_idx]
    img_lime = (img * 255).astype(np.uint8)
    pred_class = optimal_predictions[sample_idx]

    try:
        explanation = explainer.explain_instance(
            img_lime,
            predict_fn,
            top_labels=len(class_names),
            hide_color=0,
            num_samples=500,
            batch_size=32
        )

        temp, mask = explanation.get_image_and_mask(
            pred_class,
            positive_only=True,
            num_features=10,
            hide_rest=False
        )

        img_with_mask = mark_boundaries(img_lime / 255.0, mask)

        # Create heatmap
        heatmap = np.zeros(img.shape[:2])
        for j in range(1, mask.max() + 1):
            heatmap[mask == j] = 1.0

        heatmap_colored = cv2.applyColorMap(np.uint8(255 * heatmap), cv2.COLORMAP_JET)
        heatmap_colored = cv2.cvtColor(heatmap_colored, cv2.COLOR_BGR2RGB)
        overlay = cv2.addWeighted(img_lime, 0.6, heatmap_colored, 0.4, 0)

    except:
        img_with_mask = img
        heatmap = np.zeros(img.shape[:2])
        overlay = img_lime

    # Create figure
    plt.figure(figsize=(15, 5))

    plt.subplot(1, 3, 1)
    plt.imshow(img)
    plt.title('Original Retinal Scan', fontsize=14, fontweight='bold')
    plt.axis('off')

    plt.subplot(1, 3, 2)
    plt.imshow(heatmap, cmap='jet')
    plt.title('LIME Importance Map', fontsize=14, fontweight='bold')
    plt.colorbar(fraction=0.046, pad=0.04)
    plt.axis('off')

    plt.subplot(1, 3, 3)
    plt.imshow(overlay)
    plt.title('Important Regions Overlay', fontsize=14, fontweight='bold')
    plt.axis('off')

    class_name = class_names[true_labels[sample_idx]]
    plt.suptitle(f'LIME Analysis - {class_name}',
                fontsize=16, fontweight='bold')
    plt.tight_layout()
    plt.savefig(f'/content/drive/MyDrive/DR_Models/lime_example_{i+1}.png',
                dpi=300, bbox_inches='tight')
    plt.close()

print("    Individual examples saved!")
print("\nFILES SAVED:")
print("    lime_explainability.png (main visualization)")
print("    lime_example_1.png")
print("    lime_example_2.png")
print("    lime_example_3.png")
