import matplotlib.pyplot as plt
import numpy as np
from PIL import Image, ImageEnhance
from scipy import ndimage

# Load image
img_path = 'sample_images/sample/15_left.jpeg'
img = Image.open(img_path).resize((224, 224))
img_array = np.array(img)

# Create augmentations manually
fig, axes = plt.subplots(2, 4, figsize=(16, 8))
axes = axes.flatten()

# 1. Original
axes[0].imshow(img_array)
axes[0].set_title('ORIGINAL', fontsize=13, fontweight='bold', color='green')
axes[0].axis('off')

# 2. Horizontal Flip
flipped = np.fliplr(img_array)
axes[1].imshow(flipped)
axes[1].set_title('Horizontal Flip', fontsize=12)
axes[1].axis('off')

# 3. Rotate 10 degrees
rotated = ndimage.rotate(img_array, 10, reshape=False)
axes[2].imshow(rotated)
axes[2].set_title('Rotated 10°', fontsize=12)
axes[2].axis('off')

# 4. Rotate -10 degrees
rotated_neg = ndimage.rotate(img_array, -10, reshape=False)
axes[3].imshow(rotated_neg)
axes[3].set_title('Rotated -10°', fontsize=12)
axes[3].axis('off')

# 5. Brightness increase
bright_img = Image.fromarray(img_array)
enhancer = ImageEnhance.Brightness(bright_img)
brighter = enhancer.enhance(1.3)
axes[4].imshow(np.array(brighter))
axes[4].set_title('Brightness +30%', fontsize=12)
axes[4].axis('off')

# 6. Brightness decrease
darker = enhancer.enhance(0.7)
axes[5].imshow(np.array(darker))
axes[5].set_title('Brightness -30%', fontsize=12)
axes[5].axis('off')

# 7. Zoom (center crop + resize)
h, w = img_array.shape[:2]
crop_size = int(h * 0.8)
start = (h - crop_size) // 2
cropped = img_array[start:start+crop_size, start:start+crop_size]
zoomed = np.array(Image.fromarray(cropped).resize((224, 224)))
axes[6].imshow(zoomed)
axes[6].set_title('Zoomed In', fontsize=12)
axes[6].axis('off')

# 8. Combination: Flip + Rotate + Brightness
combo = np.fliplr(img_array)
combo = ndimage.rotate(combo, 15, reshape=False)
combo_img = Image.fromarray(combo.astype(np.uint8))
combo_enhanced = ImageEnhance.Brightness(combo_img).enhance(1.2)
axes[7].imshow(np.array(combo_enhanced))
axes[7].set_title('Combined Transforms', fontsize=12)
axes[7].axis('off')

plt.suptitle('Data Augmentation Examples - Manual Transformations',
             fontsize=15, fontweight='bold')
plt.tight_layout()
plt.show()

print(" Augmentation visualization complete!")
print("\n Key Observations:")
print("   Flip: Simulates different camera angles")
print("   Rotation: Accounts for patient head tilt")
print("   Brightness: Different lighting conditions")
print("   Zoom: Different distances from camera")
print("\n These variations make the model robust to real-world conditions!")
